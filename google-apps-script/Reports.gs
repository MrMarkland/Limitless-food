function createReport_(q){if(!q.jobId||!q.userId)throw Error('Report job and user required');let u=read_('Users').find(x=>x.id===q.userId);if(!u)throw Error('User not found');let p=q.period||'day',rg=range_(p,q.referenceDate),ms=read_('Meals').filter(x=>x.userId===u.id&&x.date>=rg.start&&x.date<=rg.end),vs=read_('VitaminLogs').filter(x=>x.userId===u.id&&x.date>=rg.start&&x.date<=rg.end),t=sum_(ms),n=days_(rg.start,rg.end),rep={jobId:q.jobId,userId:u.id,userName:u.name,period:p,referenceDate:q.referenceDate,startDate:rg.start,endDate:rg.end,status:'CREATING',pdfFileId:'',pdfUrl:'',createdAt:new Date().toISOString(),updatedAt:new Date().toISOString(),error:''};reportRow_(rep);try{let doc=DocumentApp.create(`${u.name} ${p} nutrition report ${rg.start}`),b=doc.getBody();b.appendParagraph('Food & Nutrition Tracker').setHeading(DocumentApp.ParagraphHeading.TITLE);b.appendParagraph(cap_(p)+' Nutrition Report').setHeading(DocumentApp.ParagraphHeading.HEADING1);b.appendParagraph(`${rg.start} to ${rg.end}`);b.appendParagraph(`User: ${u.name}`);b.appendParagraph(`Height: ${u.height} cm | Weight: ${u.weight} kg | Daily target: ${u.calories} kcal`);b.appendParagraph('Summary').setHeading(DocumentApp.ParagraphHeading.HEADING2);b.appendTable([['Metric','Consumed','Target'],['Calories',String(rd_(t.calories,0)),String(rd_(u.calories*n,0))],['Average calories/day',String(rd_(t.calories/n,0)),String(rd_(u.calories,0))],['Protein (g)',String(rd_(t.protein,1)),String(rd_(u.protein*n,1))],['Carbs (g)',String(rd_(t.carbs,1)),String(rd_(u.carbs*n,1))],['Fat (g)',String(rd_(t.fat,1)),String(rd_(u.fat*n,1))],['Fibre (g)',String(rd_(t.fiber,1)),String(rd_(u.fiber*n,1))],['Sugar (g)',String(rd_(t.sugar,1)),String(rd_(u.sugar*n,1))],['Sodium (mg)',String(rd_(t.sodium,0)),String(rd_(u.sodium*n,0))],['Water (mL)',String(rd_(t.water,0)),String(rd_(u.water*n,0))]]);b.appendParagraph('Meals').setHeading(DocumentApp.ParagraphHeading.HEADING2);let rows=[['Date','Time','Period','Meal','Calories','Protein','Sugar']];ms.sort((a,z)=>(a.date+a.time).localeCompare(z.date+z.time)).forEach(m=>rows.push([m.date,m.time,m.period,m.name,String(m.calories),String(m.protein),String(m.sugar)]));b.appendTable(rows);b.appendParagraph('Vitamins').setHeading(DocumentApp.ParagraphHeading.HEADING2);if(vs.length){let vr=[['Date','Vitamin','Quantity']];vs.forEach(v=>vr.push([v.date,v.name,`${v.quantity} ${v.unit}`]));b.appendTable(vr)}else b.appendParagraph('No vitamin records');b.appendParagraph('Automated observations').setHeading(DocumentApp.ParagraphHeading.HEADING2);obs_(t,u,n).forEach(x=>b.appendListItem(x));b.appendParagraph('This personal tracking report is not medical advice.');doc.saveAndClose();let df=DriveApp.getFileById(doc.getId()),pdf=getOrCreateReportFolder_().createFile(df.getAs(MimeType.PDF).setName(`${safe_(u.name)}-${p}-${rg.start}-nutrition-report.pdf`));df.setTrashed(true);rep.status='READY';rep.pdfFileId=pdf.getId();rep.pdfUrl=pdf.getUrl();rep.updatedAt=new Date().toISOString();reportRow_(rep)}catch(x){rep.status='ERROR';rep.error=String(x.message||x);rep.updatedAt=new Date().toISOString();reportRow_(rep);throw x}}
function reportRow_(o){let sh=ss_().getSheetByName('Reports'),row=find_(sh,o.jobId),v=SCHEMA.Reports.map(k=>o[k]===undefined?'':o[k]);if(row)sh.getRange(row,1,1,v.length).setValues([v]);else sh.appendRow(v)}
function range_(p,s){let d=parse_(s),a=new Date(d),b=new Date(d);if(p==='week'){let n=d.getDay()===0?6:d.getDay()-1;a.setDate(d.getDate()-n);b=new Date(a);b.setDate(a.getDate()+6)}if(p==='month'){a=new Date(d.getFullYear(),d.getMonth(),1);b=new Date(d.getFullYear(),d.getMonth()+1,0)}return{start:ymd_(a),end:ymd_(b)}}function parse_(s){let p=String(s).split('-').map(Number);return new Date(p[0],p[1]-1,p[2])}function ymd_(d){return Utilities.formatDate(d,CONFIG.TIMEZONE,'yyyy-MM-dd')}function days_(a,b){return Math.round((parse_(b)-parse_(a))/86400000)+1}function sum_(m){return m.reduce((t,x)=>{['calories','protein','carbs','fat','fiber','sugar','sodium','water'].forEach(k=>t[k]+=Number(x[k])||0);return t},{calories:0,protein:0,carbs:0,fat:0,fiber:0,sugar:0,sodium:0,water:0})}function obs_(t,u,n){let a=[`Average intake was ${rd_(t.calories/n,0)} calories per day.`];[['protein','Protein',0],['fiber','Fibre',0],['water','Water',0],['sugar','Sugar',1],['sodium','Sodium',1]].forEach(x=>{let v=Number(t[x[0]])||0,g=(Number(u[x[0]])||0)*n,p=g?v/g*100:0;if(!x[2]&&p<80)a.push(`${x[1]} was ${rd_(100-p,0)}% below target.`);if(x[2]&&p>100)a.push(`${x[1]} was ${rd_(p-100,0)}% above the selected limit.`)});return a}function rd_(n,d){let x=10**d;return Math.round(((Number(n)||0)+Number.EPSILON)*x)/x}function cap_(s){return String(s).charAt(0).toUpperCase()+String(s).slice(1)}function safe_(s){return String(s).replace(/[^a-z0-9]+/gi,'-').replace(/^-|-$/g,'').toLowerCase()}

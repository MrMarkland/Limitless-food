function onOpen(){SpreadsheetApp.getUi().createMenu('Food Tracker').addItem('Initialize / Repair Database','setupDatabase').addItem('Create Report Folder','getOrCreateReportFolder_').addToUi()}
function doGet(e){try{auth_(e.parameter.token);let a=e.parameter.action||'ping',d=a==='bootstrap'?bootstrap_():{message:'Food Tracker backend running'};return jsonp_(e.parameter.callback,{ok:true,data:d})}catch(x){return jsonp_(e.parameter.callback,{ok:false,error:String(x.message||x)})}}
function doPost(e){try{auth_(e.parameter.token);route_(e.parameter.action,JSON.parse(e.parameter.payload||'{}'));return ContentService.createTextOutput('OK')}catch(x){console.error(x);return ContentService.createTextOutput('ERROR')}}
function route_(a,p){let m={saveUser:'Users',saveMeal:'Meals',saveSavedFood:'SavedFoods',saveVitaminProfile:'VitaminProfiles',saveVitaminLog:'VitaminLogs',saveFridge:'Fridge'};if(m[a])upsert_(m[a],p);else if(a==='deleteRecord')softDelete_(p.sheet,p.id);else if(a==='createReport')createReport_(p);else throw Error('Unsupported action');clearCache_()}
function auth_(t){if(!CONFIG.APP_TOKEN||CONFIG.APP_TOKEN.indexOf('CHANGE_')===0)throw Error('Set APP_TOKEN in Config.gs');if(t!==CONFIG.APP_TOKEN)throw Error('Unauthorized')}
function jsonp_(cb,v){let s=String(cb||'').replace(/[^a-zA-Z0-9_$.]/g,'');if(!s)throw Error('Callback required');return ContentService.createTextOutput(s+'('+JSON.stringify(v)+');').setMimeType(ContentService.MimeType.JAVASCRIPT)}
